<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="670.0" prefWidth="950.0" styleClass="page-root" stylesheets="@../styles/cso-command.css" xmlns="http://javafx.com/javafx/10.0.2-internal" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.cso.SetVariablesController">
    <children>
        <Pane layoutX="0.0" layoutY="0.0" prefHeight="96.0" prefWidth="950.0" styleClass="page-header" />
        <Button layoutX="40.0" layoutY="32.0" mnemonicParsing="false" onAction="#setBack" styleClass="secondary-button" text="Back" />
        <Text layoutX="140.0" layoutY="40.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="page-kicker" text="OCPP COMMAND" />
        <Text layoutX="140.0" layoutY="72.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="page-title" text="Set Variables" />

        <VBox layoutX="40.0" layoutY="124.0" prefHeight="400.0" prefWidth="620.0" spacing="12.0" styleClass="surface">
            <padding>
                <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
            </padding>
            <children>
                <Label styleClass="section-title" text="Request Items" />
                <TableView fx:id="setVariableTable" prefHeight="330.0" prefWidth="584.0">
                    <columns>
                        <TableColumn fx:id="componentCol" prefWidth="145.0" text="Component">
                            <cellValueFactory>
                                <PropertyValueFactory property="component" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="variableCol" prefWidth="170.0" text="Variable">
                            <cellValueFactory>
                                <PropertyValueFactory property="variable" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="attributeTypeCol" prefWidth="130.0" text="Attribute Type">
                            <cellValueFactory>
                                <PropertyValueFactory property="attributeType" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="attributeValueCol" prefWidth="137.0" text="Attribute Value">
                            <cellValueFactory>
                                <PropertyValueFactory property="attributeValue" />
                            </cellValueFactory>
                        </TableColumn>
                    </columns>
                </TableView>
            </children>
        </VBox>

        <VBox layoutX="690.0" layoutY="124.0" prefHeight="400.0" prefWidth="220.0" spacing="9.0" styleClass="surface">
            <padding>
                <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
            </padding>
            <children>
                <Label styleClass="section-title" text="Add Item" />
                <Label styleClass="field-label" text="Component" />
                <ComboBox fx:id="componentBox" prefHeight="30.0" prefWidth="184.0" promptText="Component" />
                <Label styleClass="field-label" text="Variable" />
                <ComboBox fx:id="variableBox" prefHeight="30.0" prefWidth="184.0" promptText="Variable" />
                <Label styleClass="field-label" text="Attribute Type" />
                <ComboBox fx:id="attributeTypeBox" prefHeight="30.0" prefWidth="184.0" promptText="Attribute Type" />
                <Label styleClass="field-label" text="Attribute Value" />
                <TextField fx:id="attributeValueField" prefHeight="30.0" prefWidth="184.0" promptText="Attribute Value" />
                <HBox spacing="10.0">
                    <children>
                        <Button fx:id="addButton" mnemonicParsing="false" onAction="#AddButton" prefWidth="86.0" styleClass="secondary-button" text="Add" />
                        <Button mnemonicParsing="false" onAction="#DeleteButton" prefWidth="86.0" styleClass="danger-button" text="Delete" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <Text fx:id="componentDescription" layoutX="58.0" layoutY="555.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="description-text" wrappingWidth="290.0" />
        <Text fx:id="variableDescription" layoutX="368.0" layoutY="555.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="description-text" wrappingWidth="290.0" />

        <Pane layoutX="40.0" layoutY="584.0" prefHeight="56.0" prefWidth="870.0" styleClass="surface" />
        <Text fx:id="statusText" layoutX="58.0" layoutY="617.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="status-text" wrappingWidth="610.0" />
        <Button layoutX="724.0" layoutY="598.0" mnemonicParsing="false" onAction="#setSetVariablesRequest" prefWidth="168.0" styleClass="primary-button" text="Send Request" />
    </children>
</AnchorPane>
